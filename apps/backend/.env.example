# ==== App ====
NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000

# ==== PostgreSQL ====
# Contoh: postgresql://user:password@localhost:5432/lcs_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lcs_db
PGSSL=false

# ==== JWT - Access & Refresh Token ====
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN_DAYS=30

# ==== JWT - Email (verification & reset password), terpisah dari access/refresh secret ====
JWT_EMAIL_SECRET=change-me-email-secret
JWT_EMAIL_VERIFICATION_EXPIRES_IN=24h
JWT_RESET_PASSWORD_EXPIRES_IN=1h

# ==== Cloudflare R2 (S3-compatible) ====
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=lcs-media
R2_PUBLIC_BASE_URL=https://your-r2-public-domain.example.com
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com

# ==== Media Library ====
MEDIA_LIBRARY_QUOTA_BYTES=1073741824

# ==== Brevo (Email Provider) ====
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@example.com
BREVO_SENDER_NAME="LCS Platform"

# ==== Seed Super Admin (dipakai oleh: npm run seed:superadmin) ====
SEED_SUPERADMIN_NAME="Super Admin"
SEED_SUPERADMIN_EMAIL=superadmin@example.com
SEED_SUPERADMIN_PASSWORD=ChangeMe123!

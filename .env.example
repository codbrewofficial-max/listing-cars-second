# =========================================================
# .env.example — Root Repo
# Copy jadi ".env" di root repo (SEJAJAR docker-compose.yml),
# lalu isi semua value asli. JANGAN commit file ".env" ke Git.
#
# File ini dipakai untuk 2 hal sekaligus:
# 1. docker-compose.yml membaca POSTGRES_* untuk membuat container Postgres
# 2. Seluruh isi file ini di-inject sebagai environment variable ke
#    container backend (lewat "env_file: - .env")
# =========================================================

# ---- Postgres (dipakai docker-compose.yml, service "postgres") ----
POSTGRES_USER=lcs_user
POSTGRES_PASSWORD=ganti_dengan_password_kuat
POSTGRES_DB=lcs_production

# ---- Aplikasi Backend ----
NODE_ENV=production
PORT=4000

# Domain publik API kamu nanti (dipakai untuk generate link di email, dll)
APP_BASE_URL=https://api.namadomainkamu.com

# [BARU] Domain publik FRONTEND (Google AI Studio / domain produksi terpisah).
# WAJIB diisi domain tempat halaman React di-hosting, BUKAN domain API di atas.
# Dipakai untuk generate link /verify-email dan /reset-password di email.
FRONTEND_BASE_URL=https://namadomainkamu.com

# Sesuaikan dengan domain frontend nanti (Google AI Studio / domain kamu).
# Bisa "*" sementara saat masih development, TAPI ganti ke domain spesifik saat production.
CORS_ORIGIN=https://namadomainkamu.com

# PENTING: host "postgres" di bawah ini adalah NAMA SERVICE di docker-compose.yml,
# BUKAN "localhost" — karena backend & postgres saling terhubung lewat docker network,
# bukan lewat host VPS. Username/password/db HARUS SAMA PERSIS dengan POSTGRES_* di atas.
DATABASE_URL=postgres://lcs_user:ganti_dengan_password_kuat@postgres:5432/lcs_production

# CATATAN PENTING soal PGSSL:
# Ada bug di src/config/env.ts (z.coerce.boolean() salah mengoerksi string "false" jadi true).
# SEBELUM build image: perbaiki dulu env.ts (lihat file "env.ts.FIXED" yang disertakan),
# atau untuk sementara JANGAN tulis baris PGSSL di file ini sama sekali (biarkan pakai
# default false) — karena di dalam docker network internal, koneksi ke Postgres tidak
# butuh SSL. Kalau baris PGSSL di-uncomment di bawah ini sebelum bug diperbaiki, deployment
# akan gagal connect ke database.
# PGSSL=false

JWT_ACCESS_SECRET=ganti_dengan_random_string_panjang_dan_acak
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN_DAYS=30

JWT_EMAIL_SECRET=ganti_dengan_random_string_lain_yang_berbeda_dari_JWT_ACCESS_SECRET
JWT_EMAIL_VERIFICATION_EXPIRES_IN=24h
JWT_RESET_PASSWORD_EXPIRES_IN=1h

# ---- Cloudflare R2 (Media Library) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=lcs-media
R2_PUBLIC_BASE_URL=
R2_ENDPOINT=

MEDIA_LIBRARY_QUOTA_BYTES=1073741824

# ---- Brevo (Email) ----
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@namadomainkamu.com
BREVO_SENDER_NAME="LCS Platform"

# ---- Seed Super Admin (dipakai sekali saat "docker compose exec backend npm run seed:superadmin") ----
SEED_SUPERADMIN_NAME=Super Admin
SEED_SUPERADMIN_EMAIL=superadmin@namadomainkamu.com
SEED_SUPERADMIN_PASSWORD=ganti_dengan_password_kuat_untuk_superadmin
